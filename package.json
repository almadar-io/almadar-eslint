{
  "name": "@almadar/eslint-plugin",
  "version": "2.4.5",
  "private": false,
  "description": "Custom ESLint rules for Almadar component architecture",
  "main": "index.js",
  "files": [
    "index.js",
    "rules/",
    "utils/"
  ],
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "devDependencies": {
    "eslint": "10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-eslint.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint index.js rules/ utils/",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "jsonc-eslint-parser": "3.1.0"
  }
}
